# Docker environment configuration for Raspberry Pi deployment
# Copy this file to .env and fill in your values:
#   cp .env.docker.example .env

# Your TV's IP address (find in TV Settings > Network > Network Status)
TV_IP=192.168.1.28

# Your TV's Pre-Shared Key (set in TV Settings > Network > Home Network > IP Control)
PSK_KEY=3553

# Optional: TV's MAC address for reliable Wake-on-LAN.
# If left blank the server will attempt an ARP lookup (requires the TV to be
# on and recently communicating so it appears in the ARP table).
# Format: AA:BB:CC:DD:EE:FF  (found in TV Settings > Network > Network Status)
MAC_ADDRESS=

# Optional: restrict which browser origin may call the API.
# Defaults to * (allow any) which is fine for a private local network.
# To lock it down set this to your Pi's IP, e.g. http://192.168.1.50
CORS_ORIGIN=*
